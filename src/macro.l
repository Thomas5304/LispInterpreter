(defmacro range (max)
(let ((i 0) (res (list)))
  (while (< i max)
    (cons res i)
    (define i (+ i 1))
    )
  res
  ))
(defun pwr (x y) (if (> y 0) (* x (pwr x (- y 1))) 1))
