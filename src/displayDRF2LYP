def parse_arguments(macrofile, displayreadfile):
    parser = argparse.ArgumentParser()

    parser.add_argument("lispfiles", nargs="*")

    parser.add_argument("--display", dest="displayName", default = "", help="Selected display name")
    parser.add_argument("--drf", dest="displayDRF", default = None, help="Use displayDRF file (*.drf)")
    parser.add_argument("-m", "--map", dest="layerMap", default = None, help="Use layermap file (*.layermap or *.map")
    parser.add_argument("-t", "--techfile", dest="techfile", default = None, help="Use techfile (*.tf)")
    parser.add_argument("-r", "--repl", dest="continue_repl", action="store_true", default = False, help="Continue with REPL")

    parser.add_argument("--ignore", dest="ignore_keywords", nargs="+", action="extend", help="Keywords to ignore")
    parser.add_argument("--repl-only", dest="repl_only", default=False, action="store_true", help="Start interpreter only")

    parser.add_argument("--output", dest="output_file", action = "store", help="Name of output file (*.lyp)")

    parser.add_argument("--macros",  dest = "macrofile", action="store", default=macrofile, help=f"Overwrite lisp macro file (default: {macrofile})")
    parser.add_argument("--readdrf", dest = "readdrf",   action="store", default=displayreadfile, help=f"Overwrite lisp display read file (default: {displayreadfile})")

    return parser.parse_args()




def main() -> None:
    program = Path(sys.argv[0])
    programpath = program.parent
    programname = program.name
    
    errorstate = False
    args = parse_arguments(macrofile=programpath / "read-displayDRF.l", displayreadfile=programpath / "displayDRF-Macros.l")

    if args.repl_only:
        lisp.lisp_interpreter(args, repl = True)
        return

    if not args.displayDRF or not os.path.exists(args.displayDRF):
        print("No display DRF (*.drf) given or does not exists")
        errorstate = True
        
    if not args.layerMap or not os.path.exists(args.layerMap):
        print("No layermap (*.layermap or *.map) given or does not exists")
        errorstate = True

    if not args.techfile or not os.path.exists(args.techfile):
        print("No techfile (*.tf) given or does not exists")
        errorstate = True


    if errorstate:
        exit(1)


    lisp.lisp_interpreter(args, repl = args.continue_repl,
        vars= (
            ("use-display-drf", args.displayDRF),
            ("use-techfile-tf", args.techfile),
            ("keywords-to-ignore", args.ignore_keywords),
        )
    )
    displayDRF.createLayertable(str(Path(args.layerMap).absolute()))

    if args.output_file is None:
        lypfilename = Path(Path(args.layerMap).stem).with_suffix(".lyp") # in local dir
    else:
        lypfilename = Path(args.output_file)
    with open(lypfilename, "w") as lyphandle:
        displayDRF.generate_lyp(lyphandle, displayName = args.displayName)

    print(f"Lyp file written to {lypfilename.absolute()}")
    
if __name__ == '__main__':
    main()